datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Employee {
  id         Int       @id @default(autoincrement())
  firstName  String
  lastName   String
  email      String    @unique
  role       String
  hourlyRate Float
  createdAt  DateTime  @default(now())
  shifts     Shift[]
  payrolls   Payroll[]
}

model Shift {
  id         Int      @id @default(autoincrement())
  employee   Employee @relation(fields: [employeeId], references: [id])
  employeeId Int
  date       DateTime
  startTime  String
  endTime    String
  hours      Float
  notes      String?
  createdAt  DateTime @default(now())
}

model Payroll {
  id         Int      @id @default(autoincrement())
  employee   Employee @relation(fields: [employeeId], references: [id])
  employeeId Int
  payPeriod  String
  grossPay   Float
  tax        Float
  netPay     Float
  createdAt  DateTime @default(now())
}
